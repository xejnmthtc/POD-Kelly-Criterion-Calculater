{
  "manifest_version": 3,
  "name": "Pinnacle OddsDropper Kelly",
  "version": "0.1.0",
  "description": "Compute Kelly bet sizing when clicking odds on pinnacleoddsdropper terminal.",
  "permissions": ["storage", "tabs"],
  "host_permissions": ["https://www.pinnacleoddsdropper.com/*"],
  "content_scripts": [
    {
      "matches": ["https://www.pinnacleoddsdropper.com/terminal*"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "action": {
    "default_title": "Kelly Calculator",
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  }
}